{
    "name": "giveitsmaller/sdk",
    "description": "PHP SDK for GISL (Give It Smaller) compression service",
    "version": "0.11.0",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19",
        "giveitsmaller/contracts": "^0.29.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "phpstan/phpstan": "^2",
        "guzzlehttp/guzzle": "^7.12.1",
        "guzzlehttp/psr7": "^2.12.1",
        "http-interop/http-factory-guzzle": "^1.2",
        "symfony/yaml": "^6.4.40 || ^7.4.12"
    },
    "conflict": {
        "guzzlehttp/guzzle": "<7.12.1",
        "guzzlehttp/psr7": "<2.12.1"
    },
    "autoload": {
        "psr-4": { "Gisl\\Sdk\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": {
            "Gisl\\Sdk\\Tests\\": "tests/",
            "Gisl\\Sdk\\Tests\\Parity\\": "tests/parity/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../generated/php",
            "options": { "symlink": true }
        }
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "check": ["@test", "@phpstan"]
    }
}
